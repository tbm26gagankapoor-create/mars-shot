generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ─────────────────────────────────────────────

enum DealStage {
  DEAL_SOURCE
  RADAR
  SCREENING
  INTRO_CALL
  PARTNER_GUT_CHECK
  ACTIVE_DD
  PARTNER_REVIEW
  DECISION
}

enum DealStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  PASSED
  CLOSED_WON
  CLOSED_LOST
}

enum Sector {
  SAAS
  FINTECH
  D2C
  CONSUMER
  AI
  HEALTHTECH
  OTHER
}

enum FundingStage {
  PRE_SEED
  SEED
  SERIES_A
  OTHER
}

enum ContactType {
  VC
  CO_INVESTOR
  OPERATOR
  FOUNDER
  ADVISOR
}

enum WarmthScore {
  HOT
  WARM
  COLD
}

enum DocumentType {
  PITCH_DECK
  ONE_PAGER
  DD_MATERIAL
  PARTNER_BRIEF
  TERM_SHEET
  OTHER
}

enum AIOutputType {
  DEAL_EXTRACTION
  ONE_PAGER
  EMAIL_DRAFT
  PARTNER_BRIEF
  SCREENING_SUMMARY
}

enum IngestionChannel {
  WEB
  EMAIL
  WHATSAPP
  TELEGRAM
  MOBILE_PWA
}

enum SourceType {
  INBOUND
  VC_FORWARD
  COLD_DM
  RAZORPAY_NETWORK
  EMAIL_FORWARD
  OTHER
}

enum PassReasonCategory {
  SECTOR_MISMATCH
  STAGE_TOO_LATE
  WEAK_TEAM
  VALUATION
  COMPETITIVE
  OTHER
}

enum CompanyHealthStatus {
  ON_TRACK
  WATCH
  AT_RISK
  WRITE_OFF
}

enum RevenueType {
  MRR
  ARR
  GMV
  NONE
}

enum BusinessModel {
  SAAS
  MARKETPLACE
  TRANSACTIONAL
  D2C_ECOMMERCE
  ADVERTISING
  OTHER
}

// ─── User (Supabase Auth — minimal local record) ──────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities     Activity[]
  aiOutputs      AIOutput[]
  documents      Document[]
  calendarEvents CalendarEvent[]   @relation("CalendarEventCreator")
  termSheets     TermSheet[]       @relation("TermSheetCreator")
  emailTemplates EmailTemplate[]   @relation("EmailTemplateCreator")
  auditLogs      AuditLog[]        @relation("AuditLogUser")

  @@map("users")
}

// ─── Deal Pipeline (Section 1.1) ──────────────────────

model Deal {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Company info
  companyName String
  website     String?
  sector      Sector?
  fundingStage FundingStage?

  // Deal info
  chequeSize  Float?
  source      String?
  sourceType  SourceType?

  // Pipeline state
  stage       DealStage  @default(DEAL_SOURCE)
  status      DealStatus @default(ACTIVE)

  // SLA tracking
  stageEnteredAt DateTime @default(now())
  slaDueAt       DateTime?

  // Screening criteria (Stage 03 gate)
  sectorFit           Boolean?
  stageFit            Boolean?
  chequeFit           Boolean?
  razorpayRelevance   Boolean?
  founderBackground   String?

  // Ingestion
  ingestionChannel IngestionChannel @default(WEB)
  rawIngestionText String?

  // Call notes (Intro Call stage)
  callNotes           String?
  founderEmailConfirmed Boolean @default(false)

  // Partner stages
  onePagerApproved Boolean @default(false)
  partnerNotified  Boolean @default(false)
  ddChecklistStarted Boolean @default(false)
  partnerBriefUploaded Boolean @default(false)
  finalDecisionRecorded Boolean @default(false)

  // AI extraction metadata
  aiConfidence Float?

  // Company details
  description    String?
  location       String?
  teamSize       Int?
  foundedDate    DateTime?
  legalEntityName String?
  businessModel  BusinessModel?

  // Round & valuation
  totalRoundSize    Float?
  preMoneyValuation Float?

  // Traction & financials
  revenue          Float?
  revenueType      RevenueType?
  burnRate         Float?
  runway           Float?
  existingInvestors String?

  // Pass tracking
  passReason         String?
  passReasonCategory PassReasonCategory?

  // Referrer link
  referredByContactId String?
  referredByContact   Contact? @relation("ReferredDeals", fields: [referredByContactId], references: [id], onDelete: SetNull)

  // Tags & internal scoring
  tags            String[]
  convictionScore Int?
  nextAction      String?
  nextActionDueAt DateTime?

  // Relations
  founders       Founder[]
  documents      Document[]
  activities     Activity[]
  aiOutputs      AIOutput[]
  portfolio      PortfolioCompany?
  calendarEvents CalendarEvent[]
  termSheet      TermSheet?

  @@index([stage])
  @@index([status])
  @@index([slaDueAt])
  @@index([referredByContactId])
  @@map("deals")
}

model Founder {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name     String
  email    String?
  phone    String?
  linkedin String?
  title    String?

  // Enrichment
  previousCompanies String?
  education         String?
  twitter           String?

  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@map("founders")
}

// ─── Portfolio (Section 1.3b) ─────────────────────────

model PortfolioCompany {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyName    String
  sector         Sector?
  website        String?
  chequeAmount   Float?
  dateInvested   DateTime?
  fundingStage   FundingStage?

  founderName  String?
  founderEmail String?
  founderPhone String?

  // Investment performance
  entryValuation    Float?
  ownershipPct      Float?
  currentValuation  Float?
  proRataRights     Boolean @default(false)
  boardSeat         Boolean @default(false)

  // Operational health
  healthStatus  CompanyHealthStatus @default(ON_TRACK)
  nextMilestone String?
  coInvestors   String[]

  dealId String? @unique
  deal   Deal?   @relation(fields: [dealId], references: [id])

  followOnRounds FollowOnRound[]
  boardNotes     BoardNote[]
  activities     Activity[]
  documents      Document[]
  calendarEvents CalendarEvent[]
  kpiSnapshots   KpiSnapshot[]

  @@map("portfolio_companies")
}

model KpiSnapshot {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  periodDate DateTime
  arr        Float?
  mrr        Float?
  burnRate   Float?
  runway     Float?
  headcount  Int?
  customers  Int?
  notes      String?

  portfolioCompanyId String
  portfolioCompany   PortfolioCompany @relation(fields: [portfolioCompanyId], references: [id], onDelete: Cascade)

  @@unique([portfolioCompanyId, periodDate])
  @@index([portfolioCompanyId])
  @@map("kpi_snapshots")
}

model FollowOnRound {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  roundName      String
  amount         Float?
  leadInvestor   String?
  marsShotParticipated Boolean @default(false)
  date           DateTime?

  portfolioCompanyId String
  portfolioCompany   PortfolioCompany @relation(fields: [portfolioCompanyId], references: [id], onDelete: Cascade)

  @@map("follow_on_rounds")
}

model BoardNote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  title   String
  content String
  date    DateTime?

  portfolioCompanyId String
  portfolioCompany   PortfolioCompany @relation(fields: [portfolioCompanyId], references: [id], onDelete: Cascade)

  @@map("board_notes")
}

// ─── Ecosystem Contacts (Section 1.3c) ────────────────

model Contact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name         String
  email        String?
  phone        String?
  linkedin     String?
  organization String?
  type         ContactType @default(VC)

  warmthScore       WarmthScore @default(WARM)
  lastInteractionAt DateTime?
  interactionCount  Int         @default(0)

  sectorExpertise String[]
  coInvestmentHistory String?
  dealSourceCount Int         @default(0)

  activities     Activity[]
  documents      Document[]
  calendarEvents CalendarEvent[]
  referredDeals  Deal[]          @relation("ReferredDeals")

  @@index([warmthScore])
  @@index([lastInteractionAt])
  @@map("contacts")
}

// ─── Activity Log (polymorphic) ───────────────────────

model Activity {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  type        String
  title       String
  description String?
  metadata    Json?

  dealId             String?
  deal               Deal?             @relation(fields: [dealId], references: [id], onDelete: Cascade)
  portfolioCompanyId String?
  portfolioCompany   PortfolioCompany? @relation(fields: [portfolioCompanyId], references: [id], onDelete: Cascade)
  contactId          String?
  contact            Contact?          @relation(fields: [contactId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@index([dealId])
  @@index([portfolioCompanyId])
  @@index([contactId])
  @@index([createdAt])
  @@map("activities")
}

// ─── Documents (Supabase Storage) ─────────────────────

model Document {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name         String
  type         DocumentType
  storagePath  String
  fileSize     Int?
  mimeType     String?
  version      Int           @default(1)

  dealId             String?
  deal               Deal?              @relation(fields: [dealId], references: [id], onDelete: Cascade)
  portfolioCompanyId String?
  portfolioCompany   PortfolioCompany?  @relation(fields: [portfolioCompanyId], references: [id], onDelete: SetNull)
  contactId          String?
  contact            Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  termSheetId        String?
  termSheet          TermSheet?         @relation(fields: [termSheetId], references: [id], onDelete: SetNull)
  uploadedById       String?
  uploadedBy         User?              @relation(fields: [uploadedById], references: [id])

  versions DocumentVersion[]

  @@map("documents")
}

model DocumentVersion {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  versionNumber Int
  storagePath   String
  fileSize      Int?
  changeNote    String?

  documentId   String
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploadedById String?

  @@map("document_versions")
}

// ─── AI Outputs ───────────────────────────────────────

model AIOutput {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  type       AIOutputType
  content    String
  confidence Float?
  approved   Boolean       @default(false)
  approvedAt DateTime?

  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  generatedById String?
  generatedBy   User?   @relation(fields: [generatedById], references: [id])

  @@index([dealId])
  @@map("ai_outputs")
}

// ─── Calendar Events ─────────────────────────────────

enum CalendarEventType {
  INTRO_CALL
  PARTNER_REVIEW
  DD_MEETING
  BOARD_MEETING
  ECOSYSTEM_CATCHUP
  TASK
  OTHER
}

enum CalendarEventStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model CalendarEvent {
  id              String              @id @default(cuid())
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  title           String
  description     String?
  type            CalendarEventType   @default(OTHER)
  status          CalendarEventStatus @default(SCHEDULED)
  startAt         DateTime
  endAt           DateTime
  allDay          Boolean             @default(false)
  location        String?
  reminderMinutes Int?                @default(30)
  isSlaReminder   Boolean             @default(false)

  dealId             String?
  deal               Deal?             @relation(fields: [dealId], references: [id], onDelete: SetNull)
  portfolioCompanyId String?
  portfolioCompany   PortfolioCompany? @relation(fields: [portfolioCompanyId], references: [id], onDelete: SetNull)
  contactId          String?
  contact            Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  createdById        String?
  createdBy          User?             @relation("CalendarEventCreator", fields: [createdById], references: [id])

  @@index([startAt])
  @@map("calendar_events")
}

// ─── Term Sheets ─────────────────────────────────────

enum TermSheetStatus {
  DRAFT
  SENT
  NEGOTIATING
  SIGNED
  EXPIRED
}

model TermSheet {
  id              String          @id @default(cuid())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  valuation       Float?
  chequeSize      Float?
  equityPercent   Float?
  investorRights  String?
  boardSeat       Boolean         @default(false)
  proRataRights   Boolean         @default(false)
  liquidationPref String?
  otherTerms      String?
  status          TermSheetStatus @default(DRAFT)
  version         Int             @default(1)
  sentAt          DateTime?
  signedAt        DateTime?
  expiresAt       DateTime?

  dealId      String @unique
  deal        Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  documents   Document[]
  revisions   TermSheetRevision[]
  createdById String?
  createdBy   User?  @relation("TermSheetCreator", fields: [createdById], references: [id])

  @@map("term_sheets")
}

model TermSheetRevision {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  versionNumber Int
  changes       Json
  note          String?

  termSheetId String
  termSheet   TermSheet @relation(fields: [termSheetId], references: [id], onDelete: Cascade)

  @@map("term_sheet_revisions")
}

// ─── Email Templates ─────────────────────────────────

enum EmailTemplateType {
  SCREENING_PASS
  SCREENING_REJECT
  INTRO_CALL_BOOKING
  DD_KICKOFF
  PARTNER_BRIEF
  TERM_SHEET_SEND
  FOLLOW_UP
  CUSTOM
}

model EmailTemplate {
  id          String            @id @default(cuid())
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  name        String
  type        EmailTemplateType @default(CUSTOM)
  subject     String
  body        String
  isDefault   Boolean           @default(false)
  forStage    String?
  createdById String?
  createdBy   User?             @relation("EmailTemplateCreator", fields: [createdById], references: [id])

  @@index([type])
  @@map("email_templates")
}

// ─── Project Boards (recovered from OpenSuite) ──────

model Boards {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  v           Int      @default(0)
  title       String
  description String?
  position    Int      @default(0)
  visibility  String   @default("private")
  user        String
  sharedWith  String[]
  createdBy   String
  watchers    String[]
  favourite   Boolean  @default(false)

  /// Optional link to a PortfolioCompany (flat string ref, no Prisma relation)
  portfolioCompanyId String?

  @@map("boards")
}

model Sections {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  v         Int      @default(0)
  title     String
  board     String
  position  Int      @default(0)

  @@index([board])
  @@map("sections")
}

model Tasks {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  v          Int       @default(0)
  title      String
  content    String?
  dueDateAt  DateTime?
  priority   String    @default("MEDIUM")
  taskStatus String    @default("ACTIVE")
  section    String
  position   Int       @default(0)
  user       String
  createdBy  String
  updatedBy  String
  likes      String[]
  tags       String[]

  @@index([section])
  @@index([user])
  @@map("tasks")
}

model TasksComments {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  v         Int      @default(0)
  comment   String
  task      String
  user      String

  @@index([task])
  @@map("tasks_comments")
}

model DocumentsToTasks {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  documentId String
  taskId     String

  @@unique([documentId, taskId])
  @@map("documents_to_tasks")
}

// ─── Audit Log ───────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  entity    String
  entityId  String
  action    String
  changes   Json?
  userId    String?
  user      User?    @relation("AuditLogUser", fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
